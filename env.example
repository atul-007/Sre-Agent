# Datadog API credentials
DD_API_KEY=your-datadog-api-key
DD_APP_KEY=your-datadog-application-key
DD_SITE=datadoghq.com

# Anthropic API credentials
ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # Optional: override API base URL

# Slack Bot credentials (required for slack_bot.py)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
# SLACK_SIGNING_SECRET=your-signing-secret  # Only needed for HTTP mode (no Socket Mode)
